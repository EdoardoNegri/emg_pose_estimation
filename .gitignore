.vscode/

# C++ build outputs
code/temp/
code/build/
code/capture_data/build/

# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/

# Local data generated by recording/preprocessing/model runs
code/data/recordings/raw/*
code/data/recordings/processed/*
code/data/predictions/*
code/data/models/*
code/data/emg/raw/*
code/data/emg/processed/*
code/data/tests/*

# Keep shared configuration/metadata CSVs trackable.
!code/data/joint_limits.csv
!code/data/limb_lengths.csv
!code/data/**/.gitkeep
